# Seller wallet private key (funded with testnet USDC on Arc Testnet)
SELLER_KEY=0x_your_seller_private_key

# Buyer wallet private key (funded with testnet USDC on Arc Testnet)
BUYER_KEY=0x_your_buyer_private_key

# 8 worker agent wallets (funded with testnet USDC on Arc Testnet)
WORKER_1_KEY=0x_worker_1_private_key
WORKER_2_KEY=0x_worker_2_private_key
WORKER_3_KEY=0x_worker_3_private_key
WORKER_4_KEY=0x_worker_4_private_key
WORKER_5_KEY=0x_worker_5_private_key
WORKER_6_KEY=0x_worker_6_private_key
WORKER_7_KEY=0x_worker_7_private_key
WORKER_8_KEY=0x_worker_8_private_key

# Contract deployer/owner wallet (owns PaymentAccumulator, AgentRegistry, etc.)
DEPLOYER_KEY=0x_deployer_owner_private_key

# Uniswap Trading API key (from https://developers.uniswap.org/dashboard/)
UNISWAP_API_KEY=your_uniswap_api_key
